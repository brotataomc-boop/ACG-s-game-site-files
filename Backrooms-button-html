<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>Backrooms Launcher</title>
    <style>
        body { background: #000; color: #fff; display: flex; flex-direction: column; justify-content: center; align-items: center; height: 100vh; font-family: sans-serif; margin: 0; }
        .btn { padding: 15px 40px; font-size: 20px; cursor: pointer; background: #fbbf24; color: #000; border: none; border-radius: 8px; font-weight: bold; transition: 0.3s; box-shadow: 0 0 20px rgba(251, 191, 36, 0.4); }
        .btn:hover { background: #f59e0b; transform: scale(1.05); }
    </style>
</head>
<body>

    <button class="btn" onclick="launchBackrooms()">Enter The Backrooms</button>

    <script>
        function launchBackrooms() {
            const gameCode = `
<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8">
    <title>The Backrooms</title>
    <style>
        body, html { margin: 0; padding: 0; width: 100%; height: 100%; overflow: hidden; background: #000; }
        #gameContainer { width: 100vw; height: 100vh; background: url("https://cdn.jsdelivr.net") center center / cover; }
    </style>
    <script src="https://cdn.jsdelivr.net/gh/aKevbo/lumassets@39dcf72cfd3d38396758105fcd0a41ac651a0bc1/backrooms/TemplateData/UnityProgress.js"><\/script>
    <script src="https://cdn.jsdelivr.net/gh/aKevbo/lumassets@39dcf72cfd3d38396758105fcd0a41ac651a0bc1/backrooms/Build/UnityLoader.js"><\/script>
</head>
<body>
    <div id="gameContainer"></div>
    <script>
        var gameInstance = UnityLoader.instantiate(
            "gameContainer",
            "https://cdn.jsdelivr.net/gh/aKevbo/lumassets@39dcf72cfd3d38396758105fcd0a41ac651a0bc1/backrooms/Build/WebGL.json",
            { onProgress: UnityProgress }
        );
    <\/script>
</body>
</html>`;

            const blob = new Blob([gameCode], { type: 'text/html' });
            const blobUrl = URL.createObjectURL(blob);
            const win = window.open('about:blank', '_blank');
            
            if (win) {
                win.location.href = blobUrl;
            } else {
                alert("Pop-up blocked! Please allow pop-ups to launch the game.");
            }
        }
    </script>
</body>
</html>
